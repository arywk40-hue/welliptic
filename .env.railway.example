# LexAudit Railway Deployment Environment Variables

# LLM API Key (choose one)
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# LLM Provider (set to true for the one you want to use)
USE_GROQ=true
# USE_GEMINI=false
# USE_OPENAI=false

# Weilchain Configuration (for real MCP applet calls)
WEILCHAIN_NODE_URL=
CLAUSE_EXTRACTOR_APPLET_ID=
RISK_SCORER_APPLET_ID=

# Weilchain Wallet (use base64-encoded wallet - see scripts/encode_wallet.py)
WALLET_B64=

# Railway automatically sets PORT - no need to configure
PORT=8000
