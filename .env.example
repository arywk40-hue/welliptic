# ─── LLM ──────────────────────────────────────
# Option A: Groq (recommended — free tier, blazing fast, generous limits)
#   Signup: https://console.groq.com → Get API key from dashboard
#   Model: llama-3.3-70b-versatile (best quality/speed ratio)
GROQ_API_KEY=gsk-...your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
USE_GROQ=true

# Option B: OpenAI (requires paid credits — console.anthropic.com)
#   Set USE_OPENAI=true and paste your key below.
#   Model: gpt-4o (or gpt-5 when available)
OPENAI_API_KEY=sk-...your-openai-key
OPENAI_MODEL=gpt-4o
USE_OPENAI=false

# Option C: Anthropic (fallback — requires credits at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...your-key
ANTHROPIC_MODEL=claude-opus-4-1

# ─── LexAudit Runtime ────────────────────────
LEXAUDIT_MAX_RETRIES=2
LEXAUDIT_RETRY_BACKOFF=0.3
LEXAUDIT_RUNS_DIR=.runs
LEXAUDIT_ENFORCE_MCP=true

# ─── Weilchain ───────────────────────────────
# Generate wallet:  python3 -c "import os; open('private_key.wc','w').write(os.urandom(32).hex())"
WEILCHAIN_WALLET_PATH=./private_key.wc
WEILCHAIN_NODE_URL=https://sentinel.weilliptic.ai
WEILCHAIN_POD_URL=https://marauder.weilliptic.ai
WEILCHAIN_MCP_TIMEOUT=20.0

# ─── Deployed Applet IDs (from `make deploy`) ─
# Deploy to asia-south pod (marauder): node scripts/deploy_applets.mjs --pod asia-south
# NEVER deploy to SENATE pods (per hackathon rules)
CLAUSE_EXTRACTOR_APPLET_ID=
RISK_SCORER_APPLET_ID=
